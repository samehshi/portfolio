<div class="testimonials-section">
  {% for testimonial in entry.contents %}
    <div class="testimonial-item mb-4 p-4 border rounded position-relative">
      <!-- Testimonial Header -->
      <div class="testimonial-header mb-3">
        <div class="d-flex justify-content-between align-items-start flex-wrap">
          <div class="testimonial-author-info">
            <h6 class="testimonial-author-name font-weight-bold text-primary mb-1">
              {{ testimonial.name }}
            </h6>
            <div class="testimonial-author-details mb-2">
              <span class="testimonial-title">{{ testimonial.title }}</span>
              <span class="text-muted mx-2">•</span>
              <span class="testimonial-company font-weight-medium">{{ testimonial.company }}</span>
            </div>
            <div class="testimonial-meta">
              <span class="badge badge-outline-primary mr-2">{{ testimonial.relationship }}</span>
              {% if testimonial.year %}
                <span class="badge badge-outline-secondary mr-2">{{ testimonial.year }}</span>
              {% endif %}
              {% if testimonial.validation_status == 'verified' %}
                <span class="badge badge-success mr-2">
                  <i class="fas fa-check-circle"></i> Verified
                </span>
              {% endif %}
            </div>
          </div>
          
          <!-- LinkedIn Profile Link -->
          {% if testimonial.linkedin_profile %}
            <div class="testimonial-social">
              <a href="{{ testimonial.linkedin_profile }}" target="_blank" rel="noopener noreferrer" 
                 class="btn btn-sm btn-outline-primary" title="View LinkedIn Profile">
                <i class="fab fa-linkedin"></i>
              </a>
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Quote Icon -->
      <div class="testimonial-quote-icon">
        <i class="fas fa-quote-left text-primary"></i>
      </div>

      <!-- Testimonial Content -->
      <div class="testimonial-content mb-3">
        <blockquote class="testimonial-text">
          "{{ testimonial.testimonial }}"
        </blockquote>
      </div>

      <!-- Business Impact Highlight -->
      {% if testimonial.business_impact %}
        <div class="testimonial-impact mt-3 p-3 bg-light rounded">
          <div class="d-flex align-items-center">
            <i class="fas fa-chart-line text-success mr-2"></i>
            <strong class="text-success">Measurable Business Impact:</strong>
          </div>
          <div class="impact-text mt-1">{{ testimonial.business_impact }}</div>
        </div>
      {% endif %}

      <!-- Legal Compliance Indicator -->
      {% if testimonial.consent_obtained %}
        <div class="testimonial-compliance mt-2">
          <small class="text-muted">
            <i class="fas fa-shield-alt mr-1"></i>
            Testimonial published with explicit written consent
          </small>
        </div>
      {% endif %}
    </div>
  {% endfor %}

  <!-- Call-to-Action Section -->
  <div class="testimonials-cta mt-4 p-4 text-white rounded text-center">
    <h6 class="mb-3">Ready to Achieve Similar Results for Your Organization?</h6>
    <p class="mb-3">Join these satisfied clients who have transformed their business through data-driven insights.</p>
    <div class="cta-buttons d-flex justify-content-center flex-wrap gap-3">
      {% include cv/cta_button.liquid 
         type='success' 
         text='Schedule a Consultation' 
         action='calendar' 
         value_prop='Discuss your specific data challenges and opportunities' 
         icon='fa-solid fa-calendar-check' 
         tracking='testimonials_consultation' 
         context='testimonials' %}
      
      {% include cv/cta_button.liquid 
         type='tertiary' 
         text='View Complete Portfolio' 
         action='portfolio_download' 
         value_prop='See detailed case studies and project methodologies' 
         icon='fa-solid fa-download' 
         tracking='testimonials_portfolio' 
         context='testimonials' %}
    </div>
  </div>
</div>