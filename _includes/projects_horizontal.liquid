<div class="col mb-4">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{% include project_link.liquid project=project %}{% endif %}" class="project-link">
    <div class="card h-100 hoverable project-card">
      <div class="row no-gutters">
        <div class="col-md-6">
          {% if project.img %}
            {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 156px, 50vw" alt=project.title class="card-img" %}
          {% else %}
            {% include figure.liquid loading="eager" path="assets/img/project-placeholder.svg" sizes="(min-width: 768px) 156px, 50vw" alt=project.title class="card-img" %}
          {% endif %}
        </div>
        <div class="col-md-6">
          <div class="card-body">
            <h3 class="card-title">{{ project.title }}</h3>
            <p class="card-text">{{ project.description | truncate: 200 }}</p>
            {% if project.category %}
              <div class="project-category mb-2">
                <span class="badge badge-secondary">{{ project.category }}</span>
                {% if project.secondary_categories %}
                  {% for cat in project.secondary_categories %}
                    <span class="badge badge-light">{{ cat }}</span>
                  {% endfor %}
                {% endif %}
              </div>
            {% endif %}
            <div class="project-meta">
              {% if project.tools %}
                <div class="tools-used">
                  {% for tool in project.tools limit: 3 %}
                    <span class="tool-badge">{{ tool }}</span>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
            <div class="row ml-1 mr-1 p-0">
              {% if project.github_link or project.github %}
                <div class="github-icon">
                  <div class="icon" data-toggle="tooltip" title="Code Repository">
                    <a href="{% if project.github_link %}{{ project.github_link }}{% else %}{{ project.github }}{% endif %}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-github gh-icon"></i></a>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
