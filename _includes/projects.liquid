<div class="col">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{% include project_link.liquid project=project %}{% endif %}">
    <div class="card h-100 hoverable">
      <div class="card-img-container">
        {% if project.img %}
          {% include figure.liquid loading="eager" path=project.img sizes="250px" alt=project.title class="card-img-top" %}
        {% else %}
          {% include figure.liquid loading="eager" path="assets/img/project-placeholder.svg" sizes="250px" alt=project.title class="card-img-top" %}
        {% endif %}
      </div>
      <div class="card-body">
        <h2 class="card-title">{{ project.title }}</h2>
        <p class="card-text">{{ project.description | truncate: 150 }}</p>
        {% if project.category %}
          <div class="project-category">
            <span class="badge badge-secondary">{{ project.category }}</span>
          </div>
        {% endif %}
        <div class="row ml-1 mr-1 p-0">
          {% if project.github %}
            <div class="github-icon">
              <div class="icon" data-toggle="tooltip" title="Code Repository">
                <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
              </div>
              {% if project.github_stars %}
                <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                  <i class="fa-solid fa-star"></i>
                  <span id="{{ project.github_stars }}-stars"></span>
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </a>
</div>
